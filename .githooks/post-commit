#!/bin/bash
# .githooks/post-commit
# Auto re-indexes only the files changed in this commit
# Committed to repo — works on every machine after setup.sh

WATCHED_EXTS="pdf|md|txt|docx|dart|js|ts|py|yaml|yml|json|sql|html|rst"

CHANGED=$(git diff-tree --no-commit-id -r --name-only HEAD 2>/dev/null \
    | grep -E "\.(${WATCHED_EXTS})$" || true)

[ -z "$CHANGED" ] && exit 0

COUNT=$(echo "$CHANGED" | wc -l | tr -d ' ')
echo ""
echo "🔄 NLM: syncing $COUNT changed file(s)..."

while IFS= read -r file; do
    if [ -f "$file" ]; then
        nlm add "$file" --force --quiet && echo "  ✓ $file"
    else
        nlm delete "$file" 2>/dev/null && echo "  🗑 removed: $file"
    fi
done <<< "$CHANGED"

echo "✅ NLM index up to date"
