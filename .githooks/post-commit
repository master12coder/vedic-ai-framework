#!/bin/bash
# .githooks/post-commit
# Auto re-indexes only DOCUMENTATION files changed in this commit.
# Source code is NOT indexed — Claude Code reads that natively.

command -v nlm >/dev/null 2>&1 || exit 0

# Only doc-relevant extensions
DOC_EXTS="md|txt|rst|pdf|docx|html|yaml|yml"

# Only doc-relevant paths (docs/, root *.md, specs/, wiki/, architecture/)
CHANGED=$(git diff-tree --no-commit-id -r --name-status HEAD 2>/dev/null \
    | grep -E "\.(${DOC_EXTS})$" \
    | grep -E "^[AMD]\s+(docs/|specs/|wiki/|architecture/|[^/]+\.md$)" || true)

[ -z "$CHANGED" ] && exit 0

while IFS=$'\t' read -r status file; do
    if [ "$status" = "D" ]; then
        nlm delete "$file" --quiet 2>/dev/null || true
    elif [ -f "$file" ]; then
        nlm add "$file" --force --quiet 2>/dev/null || true
    fi
done <<< "$CHANGED"
