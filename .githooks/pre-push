#!/bin/bash
# .githooks/pre-push
# Full re-index of docs before every push.
# Catches renames/moves missed by commit hook.

command -v nlm >/dev/null 2>&1 || exit 0

# Re-index doc directories
for dir in docs specs wiki architecture; do
    [ -d "$dir" ] && nlm add "$dir" --force --quiet 2>/dev/null || true
done

# Re-index root-level .md files
for f in *.md; do
    [ -f "$f" ] && nlm add "$f" --force --quiet 2>/dev/null || true
done
