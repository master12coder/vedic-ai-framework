# DaivAI — Environment Variables
# Copy to .env and fill in your values

# ── Google OAuth (required for web app) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SECRET_KEY=change-this-to-random-secret

# ── Database ──
DATABASE_URL=sqlite:///data/daivai.db

# ── Auth ──
ALLOWED_EMAILS=
BYPASS_AUTH=false

# ── LLM API Keys (set only the ones you use) ──
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Telegram Bot (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
