# Vedic AI Framework — Environment Variables
# Copy to .env and fill in your values (or export directly)

# LLM API Keys (set only the ones you use)
GROQ_API_KEY=gsk_your_groq_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here

# Telegram Bot (optional, for delivery module)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Override config.yaml settings (optional)
# JYOTISH_LLM__DEFAULT_BACKEND=groq
# JYOTISH_OUTPUT__LANGUAGE=both
# JYOTISH_LOG_LEVEL=DEBUG
