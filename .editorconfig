# EditorConfig — consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{yaml,yml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.toml]
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[*.json]
indent_size = 2
